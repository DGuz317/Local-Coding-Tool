{
  // Documentation-only OpenCode MCP example. Keep active config outside this repo.
  // Replace paths and numeric user/group IDs before use.
  // After connecting, ask the assistant to call assistant_preflight before broad file reads.
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "repolens": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "--network",
        "none",
        "--user",
        "1000:1000",
        "-v",
        "/absolute/path/to/repo:/workspace",
        "repolens:latest",
        "mcp",
        "/workspace"
      ],
      "enabled": true,
      "timeout": 10000
    }
  }
}
