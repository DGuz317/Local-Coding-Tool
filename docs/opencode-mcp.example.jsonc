{
  // Documentation-only OpenCode MCP example. Keep active config outside this repo.
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "repolens": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "--network",
        "none",
        "--user",
        "$(id -u):$(id -g)",
        "-v",
        "$PWD:/workspace",
        "repolens:latest",
        "mcp",
        "/workspace"
      ]
    }
  }
}
