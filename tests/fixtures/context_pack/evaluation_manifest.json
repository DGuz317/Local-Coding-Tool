      "focus_hints": [],
      "expected_outcomes": {
        "first_read_files_include_any": ["src/auth/login.py", "src/auth/session.py"],
        "confidence_at_least": "medium",
        "requires_evidence": true,
        "no_source_snippets": true
      }
    },
    {
      "id": "test_focused_login_flow",
      "category": "test_focused",
      "task": "Add tests for login timeout behavior",
      "fixture_repo": "tests/fixtures/context_pack/happy-path",
      "focus_hints": [],
