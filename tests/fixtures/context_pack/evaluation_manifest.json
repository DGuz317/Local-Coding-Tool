        "supporting_configs_include_any": ["pyproject.toml", "package.json"],
        "supporting_docs_include_any": ["README.md", "docs/testing.md"],
        "candidate_commands_marked_not_run": true
      }
    },
    {
      "id": "broad_task_auth_cleanup",
      "category": "broad_task",
      "task": "Improve auth across the repository",
      "fixture_repo": "tests/fixtures/context_pack/happy-path",
      "focus_hints": [],
      "expected_outcomes": {
        "warnings_include": ["breadth_warning"],
        "bounded_by_default_budget": true,
        "does_not_dump_repository": true
      }
    },
    {
      "id": "focal_ambiguity_cache",
      "category": "focal_ambiguity",
      "task": "Fix cache refresh",
      "fixture_repo": "tests/fixtures/context_pack/ambiguous-targets",
      "focus_hints": [],
