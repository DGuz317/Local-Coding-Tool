{
  "manifest_version": "0.3.contract.v1",
  "description": "Release-blocking Context Pack fixture manifest for v0.3 implementation slices.",
  "default_budget": {
    "max_first_read_files": 5,
    "max_items_per_support_group": 5,
    "max_next_actions": 3,
    "max_agent_guidance_items": 3,
    "max_candidate_verification_commands": 5,
    "max_risk_signals": 5,
    "max_total_chars": 12000,
    "approx_token_estimate_divisor": 4
