        "ok": true,
        "confidence": "low",
        "first_read_files_max": 0,
        "does_not_dump_repository": true
      }
    },
    {
      "id": "focus_hint_valid_and_unresolved",
      "category": "focus_hint",
      "task": "Fix timeout validation",
      "fixture_repo": "tests/fixtures/context_pack/happy-path",
      "focus_hints": ["src/auth/session.py", "src/auth/missing.py"],
      "expected_outcomes": {
        "first_read_files_include_any": ["src/auth/session.py"],
        "warnings_include": ["unresolved_focus_hint"],
        "invalid_outside_root_hints_are_errors": true
      }
