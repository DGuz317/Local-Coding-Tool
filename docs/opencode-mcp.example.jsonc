{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "repolens": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "--rm",
        "-i",
        "--network",
        "none",
        "--user",
        "1000:1000",
        "-v",
        "/absolute/path/to/repo:/workspace",
        "repolens:latest",
        "mcp",
        "/workspace"
      ],
      "enabled": true
    }
  }
}
