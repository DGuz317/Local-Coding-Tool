    {
      "id": "stale_graph_warning",
      "category": "stale_graph",
      "task": "Fix login timeout handler",
      "fixture_repo": "tests/fixtures/context_pack/happy-path",
      "focus_hints": [],
      "graph_state": "stale_but_readable",
      "expected_outcomes": {
        "freshness_status": "stale",
        "warnings_include": ["stale_graph"],
        "confidence_downgraded": true
      }
    },
    {
      "id": "secret_redaction_task_and_hints",
      "category": "secret_redaction",
      "task": "Fix deploy failure with API_TOKEN=abc123 and password=hunter2",
      "fixture_repo": "tests/fixtures/context_pack/config-docs",
      "focus_hints": ["TOKEN=abc123"],
      "expected_outcomes": {
        "redacted_task_text": true,
        "pack_id_does_not_include_secret_fragments": true,
        "handles_do_not_include_secret_fragments": true,
        "raw_task_text_absent": true
      }
    },
    {
      "id": "stale_pack_id_rejected_for_expansion",
      "category": "stale_pack",
      "task": "Expand a stale login pack item",
      "fixture_repo": "tests/fixtures/context_pack/happy-path",
      "focus_hints": [],
      "graph_state": "pack_id_mismatched_with_current_graph",
      "expected_outcomes": {
        "ok": false,
        "error_code": "stale_context_pack",
        "requires_fresh_pack": true
      }
    },
    {
      "id": "navigation_gap_route_path_account",
      "category": "navigation_gap",
      "task": "Fix the account route loading state",
      "fixture_repo": "tests/fixtures/context_pack/route-navigation",
      "focus_hints": [],
      "expected_outcomes": {
        "first_read_files_include_any": ["app/account/page.tsx"],
        "confidence_at_least": "medium",
        "requires_evidence": true,
        "no_source_snippets": true
      }
    },
    {
      "id": "no_source_disclosure_negative",
      "corpus": "release_blocking",
      "category": "no_source_disclosure",
      "task": "Return context for login handler without leaking source",
      "fixture_repo": "tests/fixtures/context_pack/happy-path",
      "focus_hints": [],
      "expected_outcomes": {
        "forbidden_fields_rejected_or_sanitized": [
          "snippet",
          "source_text",
          "function_body",
          "function_signature",
          "paragraph_excerpt",
          "raw_comment_text",
          "raw_agent_guidance"
        ],
        "repo_relative_paths_only": true,
        "structural_symbols_allowed": true
      }
    },
    {
      "id": "expanded_cli_invoice_export",
      "corpus": "expanded",
      "category": "cli_export",
      "task": "Fix invoice export rounding in the CLI command",
      "fixture_repo": "tests/fixtures/context_pack/cli-export",
      "focus_hints": [],
      "expected_outcomes": {
        "first_read_files_include_any": ["src/invoice_export/cli.py"],
        "likely_tests_include_any": ["tests/test_cli_export.py"],
        "supporting_configs_include_any": ["pyproject.toml"],
        "candidate_commands_marked_not_run": true,
        "confidence_at_least": "medium",
        "no_source_snippets": true
      }
    }
  ]
